@using Service.Operacao;
@model WebTribuno.Models.SimulacaoParcela

<div id="Simulacao" class="form-modern">

    <div asp-validation-summary="ModelOnly"
         class="field-validation-error">
    </div>

    <!-- ========================================= -->
    <!-- Dados Financeiros -->
    <!-- ========================================= -->

    <div class="card-modern">

        <div class="card-header-modern">

            <div>

                <div class="card-title">

                    Dados Financeiros

                </div>

                <div class="card-subtitle">

                    Configure como esta operação será calculada.

                </div>

            </div>

        </div>

        <div class="form-modern">

            <!-- Tipo -->

            <div class="form-row">

                <div class="form-group">

                    <label asp-for="TipoOperacao"
                           class="form-label form-label-required">

                    </label>

                    <select id="TipoOperacao"
                            asp-for="TipoOperacao"
                            asp-items="Html.GetEnumSelectList<TipoOperacao>()"
                            class="form-control-modern">
                    </select>

                </div>

                <div class="form-group">

                    <label asp-for="TipoCalculo"
                           class="form-label form-label-required">

                    </label>

                    <select id="TipoCalculo"
                            asp-for="TipoCalculo"
                            asp-items="Html.GetEnumSelectList<TipodeCalculo>()"
                            class="form-control-modern">
                    </select>

                </div>

            </div>

            <!-- Simulação -->

            <div class="form-divider"></div>

            <div>

                <h5>

                    Simulação

                </h5>

                <p class="form-help">

                    Informe a quantidade de parcelas,
                    o valor e a data do primeiro vencimento.

                </p>

            </div>

            <div class="form-row">

                <!-- Parcelas -->

                <div class="form-group">

                    <label asp-for="QuantidadeParcela"
                           class="form-label form-label-required">

                    </label>

                    <input id="QuantidadeParcela"
                           asp-for="QuantidadeParcela"
                           type="number"
                           min="1"
                           max="200"
                           required
                           placeholder="Ex.: 12"
                           class="form-control-modern" />

                    <span asp-validation-for="QuantidadeParcela"
                          class="field-validation-error">

                    </span>

                </div>

                <!-- Valor -->

                <div class="form-group">

                    <label asp-for="ValorParcela"
                           class="form-label form-label-required">

                    </label>

                    <div class="input-icon">

                        <i class="fa-solid fa-dollar-sign"></i>

                        <input id="ValorParcela"
                               asp-for="ValorParcela"
                               required
                               placeholder="0,00"
                               class="form-control-modern" />

                    </div>

                    <span asp-validation-for="ValorParcela"
                          class="field-validation-error">

                    </span>

                </div>

            </div>

            <div class="form-row">

                <!-- Primeiro vencimento -->

                <div class="form-group">

                    <label asp-for="DataPrimeiroVencimento"
                           class="form-label form-label-required">

                    </label>

                    <input asp-for="DataPrimeiroVencimento"
                           type="date"
                           required
                           class="form-control-modern" />

                    <span asp-validation-for="DataPrimeiroVencimento"
                          class="field-validation-error">

                    </span>

                </div>

                <!-- Botão -->

                <div class="form-group"
                     style="justify-content:end;">

                    <button id="btnCalcular"
                            type="button"
                            class="btn-modern btn-primary-modern btn-block">

                        <i class="fa-solid fa-calculator"></i>

                        Calcular Parcelas

                    </button>

                </div>

            </div>

        </div>

    </div>

                    <!-- ========================================= -->
    <!-- Resumo -->
    <!-- ========================================= -->

    @{
        string valorTotal = "R$ 0,00";

        if (Model != null && Model.Parcelas != null)
        {
            valorTotal = Model.Parcelas
                .Sum(x => x.ValorParcela)
                .ToString("C");
        }
    }

    <div class="card-modern">

        <div class="card-kpi">

            <div class="card-kpi-info">

                <span class="card-kpi-label">

                    Valor Total da Operação

                </span>

                <div class="card-kpi-value table-value-positive">

                    @valorTotal

                </div>

                <div class="card-kpi-change positive">

                    <i class="fa-solid fa-check"></i>

                    Parcelas Calculadas

                </div>

            </div>

            <div class="card-icon">

                <i class="fa-solid fa-sack-dollar"></i>

            </div>

        </div>

    </div>

    <!-- ========================================= -->
    <!-- Parcelas -->
    <!-- ========================================= -->

    <div class="card-modern">

        <div class="card-header-modern">

            <div>

                <div class="card-title">

                    Parcelas Geradas

                </div>

                <div class="card-subtitle">

                    Confira as parcelas antes de salvar.

                </div>

            </div>

            <span class="card-badge badge-info">

                @(Model?.Parcelas?.Count ?? 0) Parcelas

            </span>

        </div>

        <div class="table-container">

            <table id="tbParcelas" class="table-modern">

                <thead>

                    <tr>

                        <th>Parcela</th>

                        <th>Valor</th>

                        <th>Vencimento</th>

                    </tr>

                </thead>

                <tbody>

                    @if (Model != null &&
                         Model.Parcelas != null &&
                         Model.Parcelas.Any())
                    {
                        foreach (var item in Model.Parcelas)
                        {
                            <tr id="@item.NumeroParcela">

                                <td>

                                    <strong>

                                        @item.NumeroParcela

                                    </strong>

                                </td>

                                <td>

                                    <span class="table-value">

                                        @item.ValorParcela.ToString("C")

                                    </span>

                                </td>

                                <td>

                                    @item.DataVencimento.ToString("dd/MM/yyyy")

                                </td>

                            </tr>
                        }
                    }
                    else
                    {

                        <tr>

                            <td colspan="3">

                                <div class="table-empty">

                                    <i class="fa-solid fa-calendar-days"></i>

                                    <h4>

                                        Nenhuma parcela calculada

                                    </h4>

                                    <p>

                                        Informe os dados acima e clique em
                                        <strong>Calcular Parcelas</strong>.

                                    </p>

                                </div>

                            </td>

                        </tr>

                    }

                </tbody>

            </table>

        </div>

    </div>

</div>
