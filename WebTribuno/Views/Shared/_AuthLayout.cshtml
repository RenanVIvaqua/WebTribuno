@{
    Layout = null;

    var authTitle = ViewData["AuthTitle"]?.ToString() ?? "Tribuno";
    var authSubtitle = ViewData["AuthSubtitle"]?.ToString() ?? "";
}

<!DOCTYPE html>

<html lang="pt-BR">

<head>

    <meta charset="utf-8" />

    <meta name="viewport"
          content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Tribuno</title>

    <!-- Bootstrap -->

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Font Awesome -->

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

    <!-- CSS -->

    <link rel="stylesheet"
          href="~/css/login.css"
          asp-append-version="true" />

</head>

<body>

    <div class="login-container">

        <!-- ========================================== -->
        <!-- Painel Esquerdo -->
        <!-- ========================================== -->

        <div class="login-left">

            <div class="brand">

                <div class="brand-icon">

                    <i class="fa-solid fa-chart-line"></i>

                </div>

                <h1>TRIBUNO</h1>

                <p class="subtitle">

                    Controle Financeiro Inteligente

                </p>

            </div>

            <div class="hero">

                <h2>

                    Organize suas finanças de forma simples.

                </h2>

                <p>

                    Cadastre receitas, despesas, acompanhe parcelas,
                    visualize indicadores e tenha total controle
                    do seu patrimônio.

                </p>

            </div>

            <div class="features">

                <div class="feature">

                    <i class="fa-solid fa-shield-halved"></i>

                    <div>

                        <h6>Segurança</h6>

                        <span>Autenticação JWT</span>

                    </div>

                </div>

                <div class="feature">

                    <i class="fa-solid fa-bolt"></i>

                    <div>

                        <h6>Performance</h6>

                        <span>Dapper + SQL Server</span>

                    </div>

                </div>

                <div class="feature">

                    <i class="fa-solid fa-diagram-project"></i>

                    <div>

                        <h6>Arquitetura Moderna</h6>

                        <span>Kafka + Event Driven</span>

                    </div>

                </div>

            </div>

        </div>

        <!-- ========================================== -->
        <!-- Painel Direito -->
        <!-- ========================================== -->

        <div class="login-right">

            <div class="login-card">

                <div class="text-center mb-4">

                    <h2>@authTitle</h2>

                    @if (!string.IsNullOrWhiteSpace(authSubtitle))
                    {
                        <p class="text-muted">

                            @authSubtitle

                        </p>
                    }

                </div>

                @RenderBody()

            </div>

            <div class="footer">

                © @DateTime.Now.Year - Tribuno

            </div>

        </div>

    </div>

    <!-- Scripts -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/login.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>