@model WebTribuno.Models.UsuarioViewModel

@{
    Layout = "_AuthLayout";

    ViewData["Title"] = "Login";
    ViewData["AuthTitle"] = "Bem-vindo";
    ViewData["AuthSubtitle"] = "Faça login para acessar sua conta";
}

<form asp-action="Logon"
      asp-controller="Login"
      method="post"
      id="loginForm">

    <div class="mb-4">

        <label asp-for="LoginUsuario" class="form-label">

            Usuário

        </label>

        <div class="input-group input-modern">

            <span class="input-group-text">

                <i class="fa-regular fa-user"></i>

            </span>

            <input asp-for="LoginUsuario"
                   class="form-control"
                   placeholder="Digite seu usuário" />

        </div>

        <span asp-validation-for="LoginUsuario"
              class="text-danger small"></span>

    </div>

    <div class="mb-4">

        <label asp-for="Senha" class="form-label">

            Senha

        </label>

        <div class="input-group input-modern">

            <span class="input-group-text">

                <i class="fa-solid fa-lock"></i>

            </span>

            <input asp-for="Senha"
                   id="Senha"
                   type="password"
                   class="form-control"
                   placeholder="Digite sua senha" />

            <button class="btn btn-outline-secondary"
                    type="button"
                    id="btnMostrarSenha">

                <i class="fa-regular fa-eye"></i>

            </button>

        </div>

        <span asp-validation-for="Senha"
              class="text-danger small"></span>

    </div>

    <div class="d-grid mb-3">

        <button id="btnEntrar"
                class="btn btn-login"
                type="submit">

            <span id="textoBotao">

                <i class="fa-solid fa-right-to-bracket"></i>

                Entrar

            </span>

            <span id="loadingBotao">

                <span class="spinner-border spinner-border-sm me-2"></span>

                Entrando...

            </span>

        </button>

    </div>

    <div class="text-center">

        <a asp-controller="CadastrarUsuario"
           asp-action="Index"
           class="link-primary">

            Criar uma conta

        </a>

    </div>

</form>

@section Scripts{

    <script src="~/js/login.js"
            asp-append-version="true"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}