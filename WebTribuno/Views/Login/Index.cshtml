@model WebTribuno.Models.UsuarioViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>

<html lang="pt-br">
<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Tribuno - Login</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />

    <link rel="stylesheet" href="~/css/login.css" asp-append-version="true" />

</head>

<body>

    <div class="login-container">

        <!-- Painel esquerdo -->

        <div class="login-left">

            <div class="brand">

                <div class="brand-icon">
                    <i class="fa-solid fa-chart-line"></i>
                </div>

                <h1>TRIBUNO</h1>

                <p class="subtitle">
                    Controle Financeiro Inteligente
                </p>

            </div>

            <div class="hero">

                <h2>
                    Organize suas finanças de forma simples.
                </h2>

                <p>
                    Cadastre receitas, despesas, acompanhe parcelas,
                    visualize indicadores e tenha total controle do
                    seu patrimônio.
                </p>

            </div>

            <div class="features">

                <div class="feature">

                    <i class="fa-solid fa-shield-halved"></i>

                    <div>
                        <h6>Segurança</h6>
                        <span>Autenticação JWT</span>
                    </div>

                </div>

                <div class="feature">

                    <i class="fa-solid fa-bolt"></i>

                    <div>
                        <h6>Performance</h6>
                        <span>Dapper + SQL Server</span>
                    </div>

                </div>

                <div class="feature">

                    <i class="fa-solid fa-diagram-project"></i>

                    <div>
                        <h6>Arquitetura Moderna</h6>
                        <span>Kafka + Event Driven</span>
                    </div>

                </div>

            </div>

        </div>

        <!-- Painel direito -->

        <div class="login-right">

            <div class="login-card">

                <div class="text-center mb-4">

                    <h2>Bem-vindo</h2>

                    <p class="text-muted">
                        Faça login para acessar sua conta
                    </p>

                </div>

                <form asp-action="Logon"
                      asp-controller="Login"
                      method="post"
                      id="loginForm">

                    <div class="mb-4">

                        <label asp-for="LoginUsuario" class="form-label">
                            Usuário
                        </label>

                        <div class="input-group input-modern">

                            <span class="input-group-text">
                                <i class="fa-regular fa-user"></i>
                            </span>

                            <input asp-for="LoginUsuario"
                                   class="form-control"
                                   placeholder="Digite seu usuário" />

                        </div>

                        <span asp-validation-for="LoginUsuario"
                              class="text-danger small"></span>

                    </div>

                    <div class="mb-4">

                        <label asp-for="Senha" class="form-label">
                            Senha
                        </label>

                        <div class="input-group input-modern">

                            <span class="input-group-text">
                                <i class="fa-solid fa-lock"></i>
                            </span>

                            <input asp-for="Senha"
                                   id="Senha"
                                   type="password"
                                   class="form-control"
                                   placeholder="Digite sua senha" />

                            <button class="btn btn-outline-secondary"
                                    type="button"
                                    id="btnMostrarSenha">

                                <i class="fa-regular fa-eye"></i>

                            </button>

                        </div>

                        <span asp-validation-for="Senha"
                              class="text-danger small"></span>

                    </div>

                    <div class="d-grid mb-3">

                        <button id="btnEntrar"
                                class="btn btn-login"
                                type="submit">

                            <span id="textoBotao">

                                <i class="fa-solid fa-right-to-bracket"></i>

                                Entrar

                            </span>

                            <span id="loadingBotao">

                                <span class="spinner-border spinner-border-sm me-2"></span>

                                Entrando...

                            </span>

                        </button>

                    </div>

                    <div class="text-center">

                        <a asp-controller="CadastrarUsuario"
                           asp-action="Index"
                           class="link-primary">

                            Criar uma conta

                        </a>

                    </div>

                </form>

            </div>

            <div class="footer">

                © @DateTime.Now.Year - Tribuno

            </div>

        </div>

    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/login.js" asp-append-version="true"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

</body>

</html>