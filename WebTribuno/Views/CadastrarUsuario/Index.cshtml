@model WebTribuno.Models.UsuarioViewModel

@{
    Layout = "_AuthLayout";

    ViewData["Title"] = "Criar Conta";

    ViewData["AuthTitle"] = "Criar Conta";

    ViewData["AuthSubtitle"] = "Cadastre-se para começar a utilizar o Tribuno.";
}

<form asp-action="Create"
      asp-controller="CadastrarUsuario"
      method="post"
      id="cadastroForm">

    <div asp-validation-summary="ModelOnly"
         class="text-danger small mb-3">
    </div>

    <!-- Nome -->

    <div class="mb-4">

        <label asp-for="Nome"
               class="form-label">

            Nome Completo

        </label>

        <div class="input-group input-modern">

            <span class="input-group-text">

                <i class="fa-regular fa-id-card"></i>

            </span>

            <input asp-for="Nome"
                   class="form-control"
                   placeholder="Digite seu nome completo" />

        </div>

        <span asp-validation-for="Nome"
              class="text-danger small"></span>

    </div>

    <!-- Usuário -->

    <div class="mb-4">

        <label asp-for="LoginUsuario"
               class="form-label">

            Usuário

        </label>

        <div class="input-group input-modern">

            <span class="input-group-text">

                <i class="fa-regular fa-user"></i>

            </span>

            <input asp-for="LoginUsuario"
                   class="form-control"
                   placeholder="Escolha um usuário" />

        </div>

        <span asp-validation-for="LoginUsuario"
              class="text-danger small"></span>

    </div>

    <!-- Email -->

    <div class="mb-4">

        <label asp-for="Email"
               class="form-label">

            E-mail

        </label>

        <div class="input-group input-modern">

            <span class="input-group-text">

                <i class="fa-regular fa-envelope"></i>

            </span>

            <input asp-for="Email"
                   type="email"
                   class="form-control"
                   placeholder="Digite seu e-mail" />

        </div>

        <span asp-validation-for="Email"
              class="text-danger small"></span>

    </div>

    <!-- Senha -->

    <div class="mb-4">

        <label asp-for="Senha"
               class="form-label">

            Senha

        </label>

        <div class="input-group input-modern">

            <span class="input-group-text">

                <i class="fa-solid fa-lock"></i>

            </span>

            <input asp-for="Senha"
                   id="Senha"
                   type="password"
                   class="form-control"
                   placeholder="Digite sua senha" />

            <button class="btn btn-outline-secondary"
                    type="button"
                    id="btnMostrarSenha">

                <i class="fa-regular fa-eye"></i>

            </button>

        </div>

        <span asp-validation-for="Senha"
              class="text-danger small"></span>

    </div>

    <!-- Botão -->

    <div class="d-grid mb-3">

        <button id="btnCadastrar"
                class="btn btn-login"
                type="submit">

            <span id="textoBotao">

                <i class="fa-solid fa-user-plus"></i>

                Criar Conta

            </span>

            <span id="loadingBotao">

                <span class="spinner-border spinner-border-sm me-2"></span>

                Criando conta...

            </span>

        </button>

    </div>

    <div class="text-center">

        <a asp-controller="Login"
           asp-action="Index"
           class="link-primary">

            Já possui uma conta? Entrar

        </a>

    </div>

</form>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}