@model WebTribuno.Models.OperacaoModel

@{
    Layout = "_DashboardLayout";
    ViewData["Title"] = "Cadastrar Operação";
}

<form id="formCadastroOperacao">

    <!-- ========================================== -->
    <!-- Header -->
    <!-- ========================================== -->

    <div class="page-header">

        <div class="page-header-left">

            <h1>

                Cadastrar Operação

            </h1>

            <p>

                Cadastre uma nova receita ou despesa.

            </p>

        </div>

    </div>

    <!-- ========================================== -->
    <!-- Dados -->
    <!-- ========================================== -->

    <div class="card-modern mb-4">

        <div class="card-header-modern">

            <div>

                <div class="card-title">

                    Dados da Operação

                </div>

                <div class="card-subtitle">

                    Informações básicas da operação.

                </div>

            </div>

        </div>

        <div class="form-modern">

            <div class="form-group">

                <label asp-for="NomeOperacao"
                       class="form-label form-label-required">

                </label>

                <input asp-for="NomeOperacao"
                       class="form-control-modern" />

                <span asp-validation-for="NomeOperacao"
                      class="field-validation-error">

                </span>

            </div>

            <div class="form-group">

                <label asp-for="Descricao"
                       class="form-label">

                </label>

                <textarea asp-for="Descricao"
                          class="form-control-modern">

                </textarea>

                <span asp-validation-for="Descricao"
                      class="field-validation-error">

                </span>

            </div>

        </div>

    </div>

    <!-- ========================================== -->
    <!-- Financeiro -->
    <!-- ========================================== -->

    <div class="card-modern mb-4">

        <div class="card-header-modern">

            <div>

                <div class="card-title">

                    Financeiro

                </div>

                <div class="card-subtitle">

                    Defina parcelas e cálculo.

                </div>

            </div>

        </div>

        @if (Model != null)
        {
            <input hidden
                   asp-for="IdOperacao" />
        }

        <div id="simulacaoContainer">

            <partial name="_GerarParcelas"
                     for="SimulacaoParcela" />

        </div>

    </div>

    <!-- ========================================== -->
    <!-- Footer -->
    <!-- ========================================== -->

    <div class="d-flex justify-content-end gap-3">

        <a asp-controller="Home"
           asp-action="Index"
           class="btn-modern btn-outline-modern">

            <i class="fa-solid fa-arrow-left"></i>

            Voltar

        </a>

        <button id="btGravar"
                type="button"
                class="btn-modern btn-primary-modern">

            <i class="fa-solid fa-floppy-disk"></i>

            Salvar Operação

        </button>

    </div>

</form>

@section Scripts {
     <script src="~/js/CalcularParcela.js" asp-append-version="true"></script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

}
